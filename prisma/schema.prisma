generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum KycStatus {
  NOT_SUBMITTED
  PENDING
  APPROVED
  REJECTED
}

enum TransactionType {
  BUY
  SELL
  DEPOSIT
  WITHDRAWAL
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
  UNDER_REVIEW
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_ON_USER
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketCategory {
  GENERAL
  PAYMENT
  KYC
  ACCOUNT
  LOYALTY
  TECHNICAL
}

enum LoyaltyPointType {
  EARN
  BONUS
  MANUAL_ADJUSTMENT
  REDEEM
  REVERSAL
  EXPIRATION
}

model User {
  id                      String                 @id @default(cuid())
  firstName               String
  lastName                String
  email                   String                 @unique
  emailVerified           DateTime?
  passwordHash            String
  phone                   String?
  country                 String?
  language                String                 @default("fr")
  role                    Role                   @default(USER)
  isActive                Boolean                @default(true)
  kycStatus               KycStatus              @default(NOT_SUBMITTED)
  loyaltyPoints           Int                    @default(0)
  loyaltyTierId           String?
  twoFactorEnabled        Boolean                @default(false)
  twoFactorSecret         String?
  notificationPreferences Json?
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt

  loyaltyTier             LoyaltyTier?           @relation(fields: [loyaltyTierId], references: [id], onDelete: SetNull)
  accounts                Account[]
  sessions                Session[]
  transactions            Transaction[]
  ticketMessages          TicketMessage[]        @relation("TicketMessageAuthor")
  tickets                 Ticket[]               @relation("TicketOwner")
  assignedTickets         Ticket[]               @relation("TicketAssignee")
  kycSubmissions          KycSubmission[]        @relation("UserKycSubmissions")
  reviewedKycSubmissions  KycSubmission[]        @relation("KycReviewer")
  loyaltyHistory          LoyaltyPointHistory[]
  adminLogs               AdminLog[]             @relation("AdminActor")
  passwordResetTokens     PasswordResetToken[]

  @@index([role, isActive])
  @@index([kycStatus])
  @@index([createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model LoyaltyTier {
  id              String    @id @default(cuid())
  name            String
  slug            String    @unique
  description     String?
  colorHex        String    @default("#16c47f")
  thresholdPoints Int
  bonusMultiplier Decimal   @default(1) @db.Decimal(5, 2)
  perks           Json?
  isDefault       Boolean   @default(false)
  isActive        Boolean   @default(true)
  sortOrder       Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  users User[]

  @@index([isActive, sortOrder])
  @@index([thresholdPoints])
}

model LoyaltyPointHistory {
  id          String           @id @default(cuid())
  userId      String
  transactionId String?
  type        LoyaltyPointType
  points      Int
  balanceAfter Int
  note        String?
  metadata    Json?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  transaction Transaction?     @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([transactionId])
}

model Transaction {
  id              String            @id @default(cuid())
  userId          String
  type            TransactionType
  asset           String
  amount          Decimal           @db.Decimal(20, 8)
  fiatCurrency    String            @default("EUR")
  fiatAmount      Decimal           @db.Decimal(14, 2)
  feeAmount       Decimal           @db.Decimal(14, 2)
  paymentMethodId String?
  status          TransactionStatus @default(PENDING)
  txReference     String            @unique
  adminNote       String?
  notes           String?
  metadata        Json?
  completedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentMethod   PaymentMethod?    @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  loyaltyEvents   LoyaltyPointHistory[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@index([type, createdAt(sort: Desc)])
  @@index([paymentMethodId])
}

model PaymentMethod {
  id                  String        @id @default(cuid())
  name                String
  slug                String        @unique
  logoUrl             String?
  description         String?
  active              Boolean       @default(true)
  recommended         Boolean       @default(false)
  maintenanceMode     Boolean       @default(false)
  supportBuy          Boolean       @default(true)
  supportSell         Boolean       @default(true)
  supportDeposit      Boolean       @default(true)
  supportWithdrawal   Boolean       @default(true)
  countryRestrictions String[]
  displayInHero       Boolean       @default(true)
  displayInCheckout   Boolean       @default(true)
  displayInFooter     Boolean       @default(true)
  trustMessage        String?
  unavailableMessage  String?
  sortOrder           Int           @default(0)
  feeFixed            Decimal       @default(0) @db.Decimal(10, 2)
  feePercent          Decimal       @default(0) @db.Decimal(5, 2)
  estimatedDelay      String?
  loyaltyBonusPoints  Int           @default(0)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  transactions Transaction[]

  @@index([active, sortOrder])
  @@index([maintenanceMode])
}

model Review {
  id            String       @id @default(cuid())
  authorName    String
  country       String?
  avatarUrl     String?
  rating        Int          @default(5)
  text          String
  locale        String       @default("fr")
  status        ReviewStatus @default(PENDING)
  featured      Boolean      @default(false)
  verifiedBadge Boolean      @default(false)
  displayDate   DateTime?
  sortOrder     Int          @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([status, featured, sortOrder])
  @@index([locale, status])
}

model FaqItem {
  id        String   @id @default(cuid())
  locale    String   @default("fr")
  question  String
  answer    String
  category  String?
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locale, active, sortOrder])
}

model Ticket {
  id              String         @id @default(cuid())
  number          String         @unique
  userId          String
  assignedAdminId String?
  subject         String
  status          TicketStatus   @default(OPEN)
  priority        TicketPriority @default(MEDIUM)
  category        TicketCategory @default(GENERAL)
  lastMessageAt   DateTime       @default(now())
  internalNote    String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user          User           @relation("TicketOwner", fields: [userId], references: [id], onDelete: Cascade)
  assignedAdmin User?          @relation("TicketAssignee", fields: [assignedAdminId], references: [id], onDelete: SetNull)
  messages      TicketMessage[]

  @@index([userId, status])
  @@index([status, priority, lastMessageAt(sort: Desc)])
}

model TicketMessage {
  id           String   @id @default(cuid())
  ticketId      String
  authorId      String
  authorRole    Role
  message       String
  isInternal    Boolean  @default(false)
  attachmentUrl String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User   @relation("TicketMessageAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
  @@index([authorId])
}

model KycSubmission {
  id               String     @id @default(cuid())
  userId           String
  reviewedById     String?
  status           KycStatus  @default(PENDING)
  documentType     String
  documentFrontUrl String
  documentBackUrl  String?
  selfieUrl        String?
  addressProofUrl  String?
  adminComment     String?
  submittedAt      DateTime   @default(now())
  reviewedAt       DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  user       User  @relation("UserKycSubmissions", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("KycReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([userId, submittedAt(sort: Desc)])
  @@index([status, submittedAt(sort: Desc)])
}

model SiteSetting {
  id          String   @id @default(cuid())
  key         String
  locale      String   @default("global")
  value       Json
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([key, locale])
  @@index([locale])
}

model BrandSetting {
  id              String   @id @default(cuid())
  brandName       String   @default("YasarPack")
  shortName       String   @default("Yasar")
  legalName       String   @default("YasarPack SAS")
  tagline         String   @default("Digital settlement platform")
  supportEmail    String
  supportPhone    String?
  primaryColor    String   @default("#16c47f")
  secondaryColor  String   @default("#49a2ff")
  accentColor     String   @default("#f6b554")
  logoText        String   @default("YP")
  faviconUrl      String?
  metaTitle       String
  metaDescription String
  footerText      String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Translation {
  id        String   @id @default(cuid())
  locale    String
  namespace String
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([locale, namespace, key])
  @@index([locale, namespace])
}

model AdminLog {
  id         String   @id @default(cuid())
  adminId     String
  action      String
  entityType  String
  entityId    String?
  details     Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  admin User @relation("AdminActor", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId, createdAt(sort: Desc)])
  @@index([entityType, entityId])
}
